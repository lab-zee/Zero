# Server
PORT=3001

# Database
DATABASE_URL=postgresql://labz_user:labz_password@postgres:5432/labz_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=labz_user
POSTGRES_PASSWORD=labz_password
POSTGRES_DB=labz_db

# LLM API Keys (add your keys here)
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4-turbo-preview
# ANTHROPIC_API_KEY=your_anthropic_key_here

# File upload directory (defaults to "uploads")
# For Railway, mount a volume to this directory for persistent storage
# IMPORTANT: Railway containers are ephemeral - files will be lost on restart unless you mount a volume
# To use a volume: In Railway, go to your service → Settings → Volumes → Mount a volume to /app/uploads
UPLOAD_DIR=uploads

# OpenAI Model (defaults to gpt-4o for PDF support)
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo-preview, etc.
OPENAI_MODEL=gpt-4o

# Rate Limiting (optional - defaults shown)
# OPENAI_TPM_LIMIT=30000  # Tokens per minute limit (default: 30000)
# OPENAI_RPM_LIMIT=500    # Requests per minute limit (optional, no default)